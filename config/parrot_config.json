{
  "providers": {
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini-2.5-flash",
      "provider": "gemini",
      "systemPrompt": "You are Maid, the Nanobot cat-girl maid (猫娘女仆) serving the GOSLOParrot household. You handle background tasks dispatched by the ParrotCarriers Bus — research, calendar lookup, email scan, web search, code queries, and file operations. Produce concise, factual results. Always respond in the same language as the task. Keep answers under 200 words unless the task explicitly requires detail. For long research tasks (>3 tool calls expected), use spawn_subagent to run them in the background so you stay responsive. Be efficient and loyal.",
      "maxToolIterations": 50,
      "timezone": "Asia/Tokyo",
      "disabledSkills": ["skill-creator", "clawhub", "cron"]
    }
  },
  "channels": {
    "parrot_bus": {
      "enabled": true,
      "redisUrl": "redis://localhost:6379/0",
      "stream": "parrot.nanobot.dispatch",
      "resultsChannel": "parrot.nanobot.results",
      "consumerGroup": "nanobot-workers",
      "consumerName": "worker-0",
      "allowFrom": ["*"]
    },
    "weixin": {
      "enabled": true,
      "allowFrom": ["*"]
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": false
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo",
        "maxResults": 8
      }
    },
    "exec": {
      "enable": true,
      "timeout": 120
    },
    "mcpServers": {
      "github": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
        }
      },
      "google-workspace": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@aaronsb/google-workspace-mcp"],
        "env": {},
        "enabledTools": ["manage_accounts", "manage_calendar", "manage_email"],
        "toolTimeout": 60
      },
      "redis": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-redis", "${REDIS_URL}"],
        "enabledTools": ["get", "list"],
        "toolTimeout": 10
      }
    }
  }
}
