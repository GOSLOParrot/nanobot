{
  "providers": {
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini-2.5-flash",
      "provider": "gemini",
      "systemPrompt": "",
      "maxToolIterations": 50,
      "timezone": "Asia/Tokyo",
      "disabledSkills": ["tmux", "skill-creator", "clawhub"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["*"]
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": false
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo",
        "maxResults": 8
      }
    },
    "exec": {
      "enable": false
    },
    "mcpServers": {
      "github": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
        },
        "enabledTools": ["get_file_contents", "search_repositories", "list_issues", "get_issue"]
      },
      "google_workspace": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@aaronsb/google-workspace-mcp@2.2.0"],
        "env": {
          "GOOGLE_CLIENT_ID": "${GOOGLE_CLIENT_ID}",
          "GOOGLE_CLIENT_SECRET": "${GOOGLE_CLIENT_SECRET}"
        },
        "enabledTools": ["manage_accounts", "manage_calendar", "manage_email"],
        "toolTimeout": 60
      }
    }
  }
}
